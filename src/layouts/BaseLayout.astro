---
// src/layouts/BaseLayout.astro
import BaseHead from '@/components/BaseHead/index.astro';
import CursorShadow from '@/components/CursorShadow/index.astro';

// 接收來自 index.astro 的 props
const { title, description, schema } = Astro.props;
---

<script>
  import { gsap } from 'gsap';
  import { ScrollToPlugin } from 'gsap/ScrollToPlugin';

  gsap.registerPlugin(ScrollToPlugin);

  const SECTION_IDS = ['about', 'experience', 'projects', 'articles', 'services', 'workflow'];

  const setupSmoothScroll = () => {
    const links = document.querySelectorAll('a[href^="#"]');
    const scrollContainer = window;

    links.forEach((link) => {
      link.addEventListener('click', (e) => {
        const targetId = link.getAttribute('href');
        if (!targetId || targetId === '#') return;

        const targetElement = document.querySelector(targetId);

        if (targetElement) {
          e.preventDefault();

          gsap.to(scrollContainer, {
            duration: 1.2,
            scrollTo: {
              y: targetElement,
              autoKill: true,
            },
            ease: 'power4.inOut',
          });

          history.pushState(null, '', targetId);
        }
      });
    });
  };

  const setupScrollSpy = () => {
    const nav = document.querySelector('.navigation-links');
    if (!nav) return;

    const setActive = (activeId: string | null) => {
      nav.querySelectorAll('.nav-link').forEach((link) => {
        if (link.getAttribute('data-section') === activeId) {
          link.classList.add('is-active');
        } else {
          link.classList.remove('is-active');
        }
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const inView: Array<{ id: string; top: number }> = [];
        entries.forEach((entry) => {
          const id = entry.target.id;
          if (!id || !SECTION_IDS.includes(id)) return;
          if (entry.isIntersecting) {
            inView.push({ id, top: entry.boundingClientRect.top });
          }
        });
        if (inView.length === 0) return;
        inView.sort((a, b) => a.top - b.top);
        setActive(inView[0].id);
      },
      { root: null, rootMargin: '-20% 0px -65% 0px', threshold: 0 }
    );

    SECTION_IDS.forEach((id) => {
      const el = document.getElementById(id);
      if (el) observer.observe(el);
    });

    requestAnimationFrame(() => {
      const y = window.scrollY + window.innerHeight * 0.3;
      let activeId: string | null = null;
      for (const id of SECTION_IDS) {
        const el = document.getElementById(id);
        if (!el) continue;
        const top = el.getBoundingClientRect().top + window.scrollY;
        if (top <= y) activeId = id;
      }
      if (activeId) setActive(activeId);
    });
  };

  const init = () => {
    setupSmoothScroll();
    setupScrollSpy();
  };

  document.addEventListener('astro:page-load', init);
  init();
</script>

<html lang="zh-Hant" data-theme="dark">
  <head>
    <BaseHead title={title} description={description} />

    {/* 🚀 GEO 100分關鍵：注入結構化資料 */}
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
  </head>
  <body>
    <a href="#main-content" class="skip-to-content">跳至主要內容</a>
    <CursorShadow />
    {/* 保持 slot，移除多餘的 main 以符合 SEO 語義化規範 */}
    <slot />
  </body>
</html>
