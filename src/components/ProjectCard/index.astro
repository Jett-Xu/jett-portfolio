---
// Project Card 元件 - 帶縮圖的專案卡片
import { Icon } from 'astro-icon/components';
import { IMAGE_FALLBACK_PATH } from '@/consts';

interface Props {
  title: string;
  image: string;
  url: string;
  tags: string[];
  stats?: string;
  content: any; // Astro Content component
}

const { title, image, url, tags, stats, content: Content } = Astro.props;
---

<article class="project-card">
  <div class="project-thumb">
    <img
      src={image}
      alt={title}
      width="180"
      height="110"
      loading="lazy"
      data-fallback={IMAGE_FALLBACK_PATH}
      onerror="this.onerror=null;this.src=this.dataset.fallback||'/placeholder.svg'"
    />
  </div>
  <div class="project-info">
    <h3 class="project-title-row">
      <a href={url} class="project-title" target="_blank" rel="noopener noreferrer">
        {title}
        <span class="icon-arrow">↗</span>
      </a>
    </h3>
    <div class="project-desc">
      <Content />
      {stats && <div class="project-meta">{stats}</div>}
    </div>
    {
      tags && tags.length > 0 && (
        <div class="project-tags">
          {tags.map((tag) => (
            <span class="project-tag">{tag}</span>
          ))}
        </div>
      )
    }
  </div>
</article>

<style>
  .project-card {
    display: flex;
    align-items: flex-start;
    background: var(--color-bg-primary);
    border-radius: 0.75rem;
    padding: 2rem;
    transition:
      background 0.3s ease,
      box-shadow 0.3s ease;
    border: 1px solid var(--color-border-secondary);
    position: relative;
    overflow: hidden;

    &:hover {
      background: var(--color-bg-glass);
      box-shadow: 0 4px 24px 0 var(--color-shadow-medium);
    }
  }

  .project-thumb {
    flex-shrink: 0;
    margin-right: 2rem;

    img {
      display: block;
      border-radius: 0.75rem;
      box-shadow: 0 1px 8px 0 var(--color-shadow-light);
      width: 120px;
      height: 80px;
      object-fit: cover;
      background: var(--color-bg-tertiary);
    }
  }

  .project-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .project-title-row {
    margin: 0;
  }

  .project-title {
    color: var(--color-primary);
    font-size: 1.2rem;
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;

    &:hover {
      color: var(--color-primary-hover);
    }

    .icon-arrow {
      font-size: 0.9em;
      opacity: 0.8;
    }
  }

  .project-desc {
    color: var(--color-text-secondary);
    font-size: 1rem;
    line-height: 1.6;

    p {
      margin: 0 0 0.5rem 0;

      &:last-child {
        margin-bottom: 0;
      }
    }

    .project-meta {
      color: var(--color-text-tertiary);
      font-size: 0.98rem;
      margin-top: 0.5rem;
    }
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.25rem;
  }

  .project-tag {
    background: var(--color-bg-tertiary);
    color: var(--color-text-secondary);
    border-radius: 999px;
    font-size: 0.92rem;
    padding: 0.35em 1.1em;
    letter-spacing: 0.02em;
  }
</style>
