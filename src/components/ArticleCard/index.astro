---
// Article Card 元件 - 帶縮圖的文章卡片
import { IMAGE_FALLBACK_PATH } from '@/consts';

interface Props {
  title: string;
  image: string;
  url: string;
  content: any; // Astro Content component
}

const { title, image, url, content: Content } = Astro.props;
---

<article class="article-card">
  <div class="article-thumb">
    <img
      src={image}
      alt={title}
      width="180"
      height="110"
      loading="lazy"
      data-fallback={IMAGE_FALLBACK_PATH}
      onerror="this.onerror=null;this.src=this.dataset.fallback||'/placeholder.svg'"
    />
  </div>
  <div class="article-info">
    <h3 class="article-title-row">
      <a href={url} class="article-title" target="_blank" rel="noopener noreferrer">
        {title} <span class="icon-arrow">↗</span>
      </a>
    </h3>
    <div class="article-desc">
      <Content />
    </div>
  </div>
</article>

<style>
  .article-card {
    display: flex;
    align-items: flex-start;
    background: var(--color-bg-primary);
    border-radius: 0.75rem; /* 約 12px，與其他卡片一致 */
    box-shadow: 0 2px 16px 0 var(--color-shadow-light);
    padding: 2rem;
    transition: background 0.3s ease, box-shadow 0.3s ease;
    border: 1px solid var(--color-border-secondary);
    position: relative;
    overflow: hidden;

    &:hover {
      background: var(--color-bg-glass);
      box-shadow: 0 4px 24px 0 var(--color-shadow-medium);
    }
  }

  .article-thumb {
    flex-shrink: 0;
    margin-right: 2rem;

    img {
      display: block;
      border-radius: 0.75rem;
      box-shadow: 0 1px 8px 0 var(--color-shadow-light);
      width: 120px;
      height: 80px;
      object-fit: cover;
      background: var(--color-bg-tertiary);
    }
  }

  .article-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .article-title-row {
    margin: 0;
  }

  .article-title {
    color: var(--color-primary);
    font-size: 1.2rem;
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;

    &:hover {
      color: var(--color-primary-hover);
    }

    .icon-arrow {
      font-size: 0.9em;
      opacity: 0.8;
    }
  }

  .article-desc {
    color: var(--color-text-secondary);
    font-size: 1rem;
    line-height: 1.6;

    p {
      margin: 0 0 0.5rem 0;

      &:last-child {
        margin-bottom: 0;
      }
    }

    /* Markdown 列表樣式 */
    ul,
    ol {
      margin: 0.5rem 0;
      padding-left: 1.5rem;
    }

    li {
      margin-bottom: 0.5rem;
    }

    /* Markdown 強調樣式 */
    strong {
      font-weight: 600;
      color: var(--color-text-primary);
    }
  }
</style>
