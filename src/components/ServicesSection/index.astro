---
import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';

const allServices = (await getCollection('services')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<section id="services" class="services-section" aria-label="服務項目">
  <header class="mobile-sticky-header">SERVICES</header>
  <div class="section-content">
    <div class="services-grid">
      {
        allServices.map(async (entry) => {
          const { Content } = await entry.render();
          const iconName = `lucide:${entry.data.icon}`;
          return (
            <article class="service-card">
              <div class="service-card-inner">
                <div class="service-icon" aria-hidden="true">
                  <Icon name={iconName} />
                </div>
                <h3 class="service-title">{entry.data.title}</h3>
                <div class="service-body">
                  <Content />
                </div>
                {entry.data.tags && entry.data.tags.length > 0 && (
                  <ul class="service-tags">
                    {entry.data.tags.map((tag) => (
                      <li class="service-tag">{tag}</li>
                    ))}
                  </ul>
                )}
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .services-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;

    @media (max-width: 1023px) {
      .section-content {
        padding-top: 2rem;
        padding-bottom: 4rem;
      }
    }
  }

  .section-content {
    flex: 1;
    padding-top: 4rem;
    padding-bottom: 4rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;

    @media (min-width: 1024px) {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }
  }

  .service-card {
    margin: 0;
  }

  .service-card-inner {
    height: 100%;
    padding: 2rem;
    background: var(--color-bg-glass);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-lg);
    transition:
      transform 0.3s ease,
      border-color 0.3s ease,
      box-shadow 0.3s ease;

    .service-card:hover & {
      transform: translateY(-4px);
      border-color: rgba(255, 255, 255, 0.18);
      box-shadow: 0 12px 40px 0 var(--color-shadow-medium);
    }
  }

  .service-icon {
    width: 2.5rem;
    height: 2.5rem;
    margin-bottom: 1.25rem;
    color: var(--color-primary);

    :global(svg) {
      width: 100%;
      height: 100%;
    }
  }

  .service-title {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0 0 1rem 0;
    color: var(--color-text-primary);
    transition: color 0.3s ease, font-weight 0.3s ease;

    .service-card:hover & {
      color: #dde0e3;
      font-weight: 700;
    }
  }

  .service-body {
    color: var(--color-text-secondary);
    font-size: 0.9375rem;
    line-height: 1.65;
    margin-bottom: 1.25rem;

    :global(p) {
      margin: 0 0 0.5rem 0;
    }
    :global(p:last-child) {
      margin-bottom: 0;
    }
  }

  .service-tags {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .service-tag {
    margin: 0;
    padding: 0.25em 0.75em;
    font-size: 0.8125rem;
    color: var(--color-primary);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
  }
</style>
