---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Footer from '@/components/Footer/index.astro';
import NavigationLinks from '@/components/NavigationLinks/index.astro';
import AboutSection from '@/components/AboutSection/index.astro';
import ExperienceSection from '@/components/ExperienceSection/index.astro';
import ProjectsSection from '@/components/ProjectsSection/index.astro';
import ArticlesSection from '@/components/ArticlesSection/index.astro';
import ServicesSection from '@/components/ServicesSection/index.astro';
import WorkflowSection from '@/components/WorkflowSection/index.astro';
import ThemeToggle from '@/components/ThemeToggle/index.astro';
import { SITE_TITLE, SITE_DESCRIPTION, SITE_URL } from '../consts';
import { Icon } from 'astro-icon/components';
import './index.scss';

// 取得並排序內容（含錯誤處理：載入失敗時顯示 fallback）
const aboutEntry = await getEntry('about', 'index');
let AboutContent: Awaited<ReturnType<NonNullable<typeof aboutEntry>['render']>>['Content'] | null =
  null;
if (aboutEntry) {
  try {
    const rendered = await aboutEntry.render();
    AboutContent = rendered.Content;
  } catch {
    AboutContent = null;
  }
}

const allExperience = (await getCollection('experience')).sort(
  (a, b) => a.data.order - b.data.order
);
const allProjects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const allArticles = (await getCollection('articles')).sort((a, b) => a.data.order - b.data.order);

// GEO 關鍵：Person Schema（使用 consts 中的 SITE_URL）
const schema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Jett',
  url: SITE_URL,
  jobTitle: 'Frontend Engineer',
  description: SITE_DESCRIPTION,
  knowsAbout: ['Frontend Development', 'Web Accessibility', 'Astro', 'React'],
};
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION} schema={schema}>
  <div class="home-container">
    <div class="theme-toggle-placement">
      <ThemeToggle />
    </div>
    <header class="header-bar">
      <div class="intro">
        <h1>Jett</h1>
        <h2>Frontend Engineer</h2>
        <p>一位致力於打造優質使用者體驗的前端工程師</p>
        <NavigationLinks />
      </div>

      <ul class="social-media" aria-label="社群連結">
        <li>
          <a href="#" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
            <Icon name="lucide:github" />
            <span class="sr-only">前往我的 GitHub 頁面</span>
          </a>
        </li>
        <li>
          <a href="#" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <Icon name="lucide:linkedin" />
            <span class="sr-only">前往我的 LinkedIn 頁面</span>
          </a>
        </li>
        <li>
          {/* TODO: [由 Jett 補充內容] 請填入實際 Email */}
          <a href="mailto:test@test.com" aria-label="Email">
            <Icon name="lucide:mail" />
            <span class="sr-only">發送電子郵件給我</span>
          </a>
        </li>
        </ul>
    </header>

    <main id="main-content" class="main-content">
      <AboutSection content={AboutContent} />
      <ExperienceSection experiences={allExperience} />
      <ProjectsSection projects={allProjects} />
      <ArticlesSection articles={allArticles} />
      <ServicesSection />
      <WorkflowSection />
      <Footer />
    </main>
  </div>
</BaseLayout>
